# R
.Rhistory
.RData
.Rproj.user/

# Local config (user-specific paths — use local_paths.yaml.example as template)
config/local_paths.yaml
config/.chapter99_hash
config/.chapter99_pending

# API credentials (never commit tokens)
.env

# Data files (large)
# HTS archives: raw .json are ignored, but the gzipped .json.gz versions ARE
# committed (~30 MB total). The static download host is blocked for retrospective
# revisions (see src/02_download_hts.R), so the repo must carry them itself.
data/hts_archives/*.json
data/hts_archives/*.json.gz
data/hts_archives/_archive/
# HTS change-record PDFs — external/reference docs, not build inputs (data stays external)
data/hts_change_record/
data/processed/
data/timeseries/
data/timeseries_parallel/
data/timeseries_specs/
data/timeseries_specs_full/
data/timeseries_6d/
data/timeseries_p8/
data/tpc/*.csv
data/tpc/*.png
data/us_notes/*.pdf
# pdftotext extractions: derived from the PDFs above (build reads PDFs directly,
# not these). A few rev_5/6/7/10 .txt remain tracked as line-number citation
# anchors; new extractions stay local only.
data/us_notes/chapter99_*.txt
data/cbp/
data/dataweb/
data/spim/
data/weights/

# Output files (all regenerated by pipeline)
output/
snapshots/
changes/
exports/
test_output/
logs/

# Large DataWeb source dumps (re-downloaded via src/download_usmca_dataweb.R)
resources/USITC - USMCA - *.xlsx

# Diagnostic CSVs emitted by verification scripts (regenerable)
resources/*_diagnostic.csv

# DataWeb HTTP debugging artifacts (request payloads, raw responses)
scripts/payload_*.json
scripts/curl_out/

# Temp/diagnostic scripts
tmpclaude-*
*.tmp
*.log
check_*.R
/test_*.R
test_*.txt
analyze_*.R
_*.R
*.ps1
*.sh

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Internal working files
todo.md
blog*/

# Analysis docs and rendered output (internal working documents)
docs/analysis/*.md
docs/analysis/*.html
docs/analysis/*.pdf

# Additional data directories
data/federal_register/
data/us_notes/*.csv

# Claude
.claude/

# Parity golden reference (large build artifacts; capture locally)
tests/golden/
.Rapp.history
